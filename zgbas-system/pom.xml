<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>com.spt</groupId>
        <artifactId>zgbas-plus</artifactId>
        <version>1.0.0-SNAPSHOT</version>
        <relativePath>../pom.xml</relativePath>
    </parent>
    <artifactId>zgbas-system</artifactId>
    <packaging>jar</packaging>

    <!-- D-08/D-09: system <- common, framework. NO dependency on quartz (anti-cycle constraint). -->
    <dependencies>
        <dependency>
            <groupId>com.spt</groupId>
            <artifactId>zgbas-common</artifactId>
        </dependency>
        <dependency>
            <groupId>com.spt</groupId>
            <artifactId>zgbas-framework</artifactId>
        </dependency>

        <!-- Lombok: data-layer support types (entities/vo) use @Data etc.
             Version managed by spring-boot-starter-parent (root grandparent).
             Common declares it optional so it is NOT transitive — declare directly. -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <optional>true</optional>
        </dependency>

        <!-- UserAgentUtils: ShiroDbRealm (com.spt.bas.web.shiro, ported Plan 03-01) parses
             User-Agent header for login audit logging. Version managed by root dependencyManagement. -->
        <dependency>
            <groupId>eu.bitwalker</groupId>
            <artifactId>UserAgentUtils</artifactId>
        </dependency>

        <!-- Phase 4 D-P4-04: rocketmq-spring-boot-starter verbatim from source basCore/pom.xml
             (<rocketmq-version>2.2.2</rocketmq-version>). Wave 2 infra照搬 includes the 22-file
             basServer/rocketmq package; three non-rocketmq files (api/MQApi, api/WorkTargetApi,
             command/BasCommandExecutor) import it at compile time. The starter's producer is
             lazy-connecting — context boot does NOT contact the broker (RESEARCH A2), so it is
             safe for the D-P4-06 startup verification. Version pinned per D-P2-08 (no 2.3.x bump). -->
        <dependency>
            <groupId>org.apache.rocketmq</groupId>
            <artifactId>rocketmq-spring-boot-starter</artifactId>
            <version>2.2.2</version>
        </dependency>
    </dependencies>
    <!-- Library jar: plain jar only, not a boot module, no fat-jar packaging. -->
</project>
